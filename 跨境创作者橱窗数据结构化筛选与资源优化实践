  }).sort((a, b) => b.rate - a.rate);
}

// 按品类聚合数据
function groupByCategory(list) {
  return list.reduce((res, item) => {
    res[item.category] = res[item.category] || [];
    res[item.category].push(item);
    return res;
  }, {});
}

