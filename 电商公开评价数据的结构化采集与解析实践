def parse_comment():
    res = get_comment_data()
    comment_list = res["data"]["comments"]
    # 数据结构化整理
    structured_data = []
    for item in comment_list:
        structured_data.append({
            "评分": item["score"],
            "评价内容": item["content"],
            "评价时间": item["time"]
        })
    return structured_data

# 输出标准化数据
