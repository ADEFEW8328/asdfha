# -*- coding:utf-8 -*-
# TikTok 公开资源简易获取 仅技术学习使用
import requests
import time

# 请求头模拟正常浏览器访问
headers = {
    "User-Agent":"Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 Chrome/120.0.0.0 Safari/537.36"
}

def get_tiktok_public_info(profile_url):
    try:
        resp = requests.get(profile_url, headers=headers, timeout=15)
        time.sleep(2)  # 延时防风控
        if resp.status_code == 200:
            print("页面公开资源访问成功")
            print("页面文本长度：", len(resp.text))
            return resp.text
        else:
            print("访问失败，状态码：",resp.status_code)
            return ""
    except Exception as e:
        print("请求异常：",str(e))
        return ""

if __name__ == "__main__":
    # 替换为公开创作者主页链接
    url = "https://www.tiktok.com/xxx"
    get_tiktok_public_info(url)
